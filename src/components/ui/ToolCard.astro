---
import { Icon } from "astro-icon/components";

import NavLink from "@/components/nav-link.astro";
const { titleCard, what, why, how, questions, icon, href } = Astro.props as {
	titleCard: string;
	what?: string;
	why?: string;
	how?: string;
	questions?: string;
	icon?: string;
    href: string
};
---

<div class="grid lg:grid-cols-[180px_1fr] gap-6 border-neutral-300 rounded-md bg-white shadow-lg p-5">
	<div class="flex items-center justify-center">
			<Icon
			name={`lucide:${icon}`}
			class="size-28 md:size-36 text-brand-700 stroke-1.5"
			/>
	</div>
	<div class="grid gap-y-3">
		<h2 class="text-lg md:text-2xl text-brand-800 font-semibold">{titleCard}</h2>
		<dl class="md:grid grid-cols-[auto_1fr] gap-x-2">
			<dt class="font-semibold">What:</dt>
			<dd>{what}</dd>
		
			{why && (
                <dt class="font-semibold">Why:</dt>
			    <dd>{why}</dd>
            )}
		
			{how && (
                <dt class="font-semibold">How:</dt>
			    <dd>{how}</dd>
            )}
		
			{questions && (
                <dt class="font-semibold">Questions:</dt>
			    <dd>{questions}</dd>
            )}
		</dl>
        <NavLink href={href} class="place-self-end font-semibold bg-brand-600/90 hover:bg-brand-400 text-brand-50 hover:text-brand-950 py-2 px-4 rounded-md transition border border-neutral-300">Open</NavLink>
	</div>
</div>
