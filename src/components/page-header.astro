---
import NavLink from "./nav-link.astro";
import logo from "../../public/assets/images/logo.svg";
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
---

<header class="md:sticky top-0 bg-brand-800 min-w-full z-50">
  <div
    class="w-full p-3 md:px-8 grid grid-cols-[1fr_auto] gap-4 md:gap-8 justify-between"
  >
    <div class="flex items-center gap-x-4">
      <h1 class="text-brand-100 self-center font-semibold">
        <NavLink href="/" class="text-brand-50 flex items-center gap-x-2"
          ><Image
            src={logo}
            alt=""
            width="40"
            height="40"
            loading="lazy"
          /><span class="2xl:text-2xl text-sm">Medieval Reception of the Roman Conquest of Jerusalem</span></NavLink
        >
      </h1>
    </div>
    <nav-bar class="lg:hidden">
      <button
        id="hamburger"
        class="inline-flex items-center p-2 w-10 h-10 justify-center text-sm text-brand-50 rounded-lg"
        aria-controls="navbar-default"
        aria-expanded="false"
      >
        <span class="sr-only">Open main menu</span>
        <svg
          class="w-5 h-5"
          aria-hidden="true"
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 17 14"
        >
          <path
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M1 1h15M1 7h15M1 13h15"></path>
        </svg>
      </button>
    </nav-bar>

    <nav
      class="hidden lg:flex items-center gap-x-2 text-brand-50 text-lg font-semibold"
    >
    <ul class="flex items-start gap-x-8">
    
       <li class="relative group">
        <button class="flex gap-0.5 items-center" aria-haspopup="true"
          aria-expanded="false">Passages  
          <Icon aria-hidden="true" class="size-4.5 transition-transform group-hover:rotate-180" name="lucide:chevron-down" />
        </button>
 
        <div class="absolute left-0 top-full hidden w-48 bg-brand-800 rounded-md p-3 group-hover:grid">
          <NavLink
        class="hover:underline underline-offset-4 hover:text-brand-200 p-2"
        href="/data/passages">View all Passages</NavLink>
        <NavLink
          class="hover:underline underline-offset-4 hover:text-brand-200 p-2"
          href="/tools/text-comparisons">Text comparison</NavLink
        >
         <NavLink
          class="hover:underline underline-offset-4 hover:text-brand-200 p-2"
          href="/tools/ai-graph">AI text comparison</NavLink
        >
       
        </div>
      </li>
     <li> <NavLink
        class="hover:underline underline-offset-4 hover:text-brand-200 p-2"
        href="/data/works">Works</NavLink>
      </li>
     <li> <NavLink
        class="hover:underline underline-offset-4 hover:text-brand-200 p-2"
        href="/data/manuscripts">Manuscripts</NavLink>
      </li>
     <li> <NavLink
        class="hover:underline underline-offset-4 hover:text-brand-200 p-2"
        href="/data/authors">Authors</NavLink>
      </li>
     <li> <NavLink
        class="hover:underline underline-offset-4 hover:text-brand-200 p-2"
        href="/data/keywords">Keywords</NavLink>
      </li>
      <li> <NavLink
        class="hover:underline underline-offset-4 hover:text-brand-200 p-2"
        href="/data/clusters">Clusters</NavLink>
      </li>
       <li class="relative group">
        <button class="flex gap-0.5 items-center" aria-haspopup="true"
          aria-expanded="false">References  
          <Icon aria-hidden="true" class="size-4.5 transition-transform group-hover:rotate-180" name="lucide:chevron-down" />
        </button>
 
        <div class="absolute left-0 top-full hidden w-48 bg-brand-800 rounded-md p-3 group-hover:grid">
          <NavLink
        class="hover:underline underline-offset-4 hover:text-brand-200 p-2"
        href="/data/liturgical-refs">Liturgical References</NavLink>
       <NavLink
        class="hover:underline underline-offset-4 hover:text-brand-200 p-2"
        href="/data/biblical-refs">Biblical References</NavLink>
       
        </div>
      </li>
      <li class="relative group">
        <button class="flex gap-0.5 items-center" aria-haspopup="true"
          aria-expanded="false">Data  
          <Icon aria-hidden="true" class="size-4.5 transition-transform group-hover:rotate-180" name="lucide:chevron-down" />
        </button>
 
        <div class="absolute left-0 top-full hidden w-48 bg-brand-800 rounded-md p-3 group-hover:grid">
          <NavLink
          class="hover:underline underline-offset-4 hover:text-brand-200 p-2"
          href="/data/passages">Passages</NavLink
        >
        <NavLink
          class="hover:underline underline-offset-4 hover:text-brand-200 p-2"
          href="/data/works">Works</NavLink
        >
         <NavLink
          class="hover:underline underline-offset-4 hover:text-brand-200 p-2"
          href="/data/authors">Authors</NavLink
        >
        <NavLink
          class="hover:underline underline-offset-4 hover:text-brand-200 p-2"
          href="/data/keywords">Keywords</NavLink
        >
         <NavLink
          class="hover:underline underline-offset-4 hover:text-brand-200 p-2"
          href="/data/clusters">Clusters</NavLink
        >
        <NavLink
          class="hover:underline underline-offset-4 hover:text-brand-200 p-2"
          href="/data/liturgical-refs">Liturgical references</NavLink
        >
        <NavLink
          class="hover:underline underline-offset-4 hover:text-brand-200 p-2"
          href="/data/biblical-refs">Biblical references</NavLink
        >
         <NavLink
          class="hover:underline underline-offset-4 hover:text-brand-200 p-2"
          href="/data/manuscripts">Manuscripts</NavLink
        >
        
        </div>
      </li>
     <li class="relative group">
        <button class="flex gap-0.5 items-center" aria-haspopup="true"
          aria-expanded="false">Tools  
          <Icon aria-hidden="true" class="size-4.5 transition-transform group-hover:rotate-180" name="lucide:chevron-down" />
        </button>
 
        <div class="absolute left-0 top-full hidden w-48 bg-brand-800 rounded-md p-3 group-hover:grid">
          <NavLink
          class="hover:underline underline-offset-4 hover:text-brand-200 p-2"
          href="/tools/explore">Patterns</NavLink
        >
        <NavLink
          class="hover:underline underline-offset-4 hover:text-brand-200 p-2"
          href="/tools/dashboard">Dashboard</NavLink
        >
         <NavLink
          class="hover:underline underline-offset-4 hover:text-brand-200 p-2"
          href="/tools/text-comparisons">Text comparison</NavLink
        >
         <NavLink
          class="hover:underline underline-offset-4 hover:text-brand-200 p-2"
          href="/tools/ai-graph">AI text comparison</NavLink
        >
          <NavLink
          class="hover:underline underline-offset-4 hover:text-brand-200 p-2"
          href="/noske-search">Linguistic search</NavLink
        >
        </div>
      </li>
       <li class="relative group">
        <button class="flex gap-0.5 items-center" aria-haspopup="true"
          aria-expanded="false">About  
          <Icon aria-hidden="true" class="size-4.5 transition-transform group-hover:rotate-180" name="lucide:chevron-down" />
        </button>
 
        <div class="absolute left-0 top-full hidden w-48 bg-brand-800 rounded-md p-3 group-hover:grid">
          <NavLink
            class="hover:underline underline-offset-4 hover:text-brand-200 p-2"
            href="/about/project">About the project</NavLink
          >
          <NavLink
            class="hover:underline underline-offset-4 hover:text-brand-200 p-2"
            href="/about/technical">Technical realisation</NavLink
          >
          <NavLink
            class="hover:underline underline-offset-4 hover:text-brand-200 p-2"
            href="/about/oai-pmh">OAI-PMH Interface</NavLink
          >
           <NavLink
            class="hover:underline underline-offset-4 hover:text-brand-200 p-2"
            href="/about/faqs">FAQs</NavLink
          >
        </div>
      </li>      
      
      
      <li>
        <NavLink
          class="hover:underline underline-offset-4 hover:text-brand-200 p-2"
          href="/advanced-search" reload>Advanced Search</NavLink>
      </li>
    </ul>
    </nav>
  </div>
  <div id="nav-links" class="hidden rounded-xs grid grid-cols-1 p-5">
    <NavLink
      class="py-1 px-3 hover:text-brand-200 text-brand-50"
      href="/passages">Passages</NavLink
    >    
    <NavLink class="py-1 px-3 hover:text-brand-200 text-brand-50" href="/works"
      >Works</NavLink
    >
    <NavLink
      class="py-1 px-3 hover:text-brand-200 text-brand-50"
      href="/manuscripts">Manuscripts</NavLink
    >
    <NavLink
      class="py-1 px-3 hover:text-brand-200 text-brand-50"
      href="/authors">Authors</NavLink
    >
     <NavLink
      class="py-1 px-3 hover:text-brand-200 text-brand-50"
      href="/biblical-refs">Biblical References</NavLink
    >
    <NavLink
      class="py-1 px-3 hover:text-brand-200 text-brand-50"
      href="/liturgical-refs">Liturgical References</NavLink
    >
    <NavLink
      class="py-1 px-3 hover:text-brand-200 text-brand-50"
      href="/keywords">Keywords</NavLink
    >  
    <NavLink
      class="py-1 px-3 hover:text-brand-200 text-brand-50"
      href="/clusters">Clusters</NavLink
    >  
    <NavLink
      class="py-1 px-3 hover:text-brand-200 text-brand-50"
      href="/ai-graph">AI text comparison</NavLink
    >
    <NavLink class="py-1 px-3 hover:text-brand-200 text-brand-50" href="/explore"
    >Patterns</NavLink
    >
    <NavLink class="py-1 px-3 hover:text-brand-200 text-brand-50" href="/about"
      >About</NavLink
    >
    <NavLink
      class="py-1 px-3 hover:text-brand-200 text-brand-50"
      href="/advanced-search" reload>Advanced Search</NavLink
    >
  </div>

  <script src="@/lib/menu.js"></script>
</header>
