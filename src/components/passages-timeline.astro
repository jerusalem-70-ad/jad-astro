---
export interface Props {
  height?: number;
  dataSource?: 'table' | 'search'; // Add prop to identify data source
}
const { height = 400, dataSource = 'table' } = Astro.props;
---

<div class="passages-timeline-container">
  <div id="timeline-loading" class="flex items-center justify-center h-[400px]">
    <span class="animate-spin mr-2">&#9696;</span>
    <span>Graph loading...</span>
  </div>
  <div
    id="passages-timeline"
    class="hidden sm:block border border-neutral-800 mb-5"
    style={`height: ${height}px`}
    data-source={dataSource}
  >
  </div>
</div>

<script>
  import * as echarts from "echarts";
  import { forceSimulation, forceCollide, forceX, forceY } from "d3-force";
  import { extent } from "d3-array";
  import { withBasePath } from "@/lib/withBasePath";

  declare global {
    interface Window {
      passagesTimelineData?: any[];
      timelineChart?: any;
      updateTimelineColors?: (filteredIds: Set<string>) => void;
      initializeTimeline?: (data: any[]) => void;
    }
  }

  // Make the update function globally available
  window.updateTimelineColors = function(filteredIds: Set<string>) {
    const timelineChart = window.timelineChart;
    if (!timelineChart) return;

    // Get current chart option
    const currentOption = timelineChart.getOption();
    if (!currentOption.series || !currentOption.series[0]) return;

    // Update the scatter series data with colors
    const updatedData = currentOption.series[0].data.map((node: any) => ({
      ...node,
      itemStyle: {
        color: filteredIds.has(node.id)
          ? "#a92d03"  // Red/brown for filtered items
          : "#FFD700", // Gold for non-filtered
        opacity: filteredIds.has(node.id) ? 0.9 : 0.3, // Make non-filtered items more transparent
      },
    }));

    // Update the chart
    timelineChart.setOption({
      series: [
        {
          data: updatedData,
        },
      ],
    });
  };

  // Make the initialization function globally available
  window.initializeTimeline = function(timelineData: any[]) {
    const chartElement = document.getElementById("passages-timeline");
    if (!chartElement) return;

    // If chart already exists, destroy it first
    if (window.timelineChart) {
      window.timelineChart.dispose();
    }

    if (!timelineData || !timelineData.length) {
      console.warn("No timeline data available");
      const loadingDiv = document.getElementById("timeline-loading");
      if (loadingDiv) {
        loadingDiv.innerHTML = '<span>No data available</span>';
      }
      return;
    }

    // Calculate date extent
    const dateExtent = extent(timelineData, (d: any) => d.date_post_quem);
    const [minDate, maxDate] = dateExtent;

    // Config values
    const nodeRadius = 3;
    const nodePadding = 1;
    const collideStrength = 0.7;
    const xStrength = 0.1;
    const yStrength = 0.2;

    // Prepare nodes
    const simulationData = timelineData.map((item: any) => ({
      ...item,
      x: item.date_post_quem,
      y: 0,
      date: new Date(item.date_post_quem, 0),
    }));

    // Force simulation
    const simulation = forceSimulation()
      .force(
        "collide",
        forceCollide(nodeRadius + nodePadding).strength(collideStrength)
      )
      .force("x", forceX((d: any) => d.date_post_quem).strength(xStrength))
      .force("y", forceY(0).strength(yStrength));

    simulation.nodes(simulationData);

    // Run simulation
    for (let i = 0; i < 300; i++) {
      simulation.tick();
    }
    simulation.stop();

    // Prepare ECharts option
    const option = {
      title: {
        text: "Passages Timeline",
        left: "center",
      },
      tooltip: {
        trigger: "item",
        formatter: function (params: any) {
          return `
            <strong>#${params.data.id.substring(16)}</strong><br/>
            <strong>Author:</strong> ${params.data.author}<br/>
            <strong>Work:</strong> ${params.data.work_title}<br/>
            <strong>Date:</strong> ${params.data.date_post_quem}- ${params.data.date_ante_quem}<br/>
          `;
        },
      },
      xAxis: {
        type: "value",
        name: "Year",
        min: minDate - 10,
        max: maxDate + 10,
        position: "bottom",
        axisLabel: {
          fontSize: 12,
          interval: function (_index: number, value: number) {
            return value % 50 === 0;
          },
        },
        splitNumber: 10,
      },
      yAxis: {
        type: "value",
        show: false,
        min: "dataMin",
        max: "dataMax",
      },
      grid: {
        bottom: 40,
      },
      dataZoom: [
        {
          type: "inside",
          xAxisIndex: 0,
          filterMode: "none",
        },
      ],
      series: [
        {
          type: "scatter",
          symbolSize: nodeRadius * 2,
          itemStyle: {
            color: "#FFD700",
            opacity: 0.8,
          },
          data: simulationData.map((node: any) => ({
            value: [node.x, node.y],
            ...node,
          })),
        },
      ],
    };

    const chart = echarts.init(chartElement);
    chart.setOption(option);

    // Show chart after loading
    const loadingDiv = document.getElementById("timeline-loading");
    if (loadingDiv) loadingDiv.style.display = "none";
    chartElement.style.display = "block";

    chart.on("click", function (params: any) {
      if (params.data && params.data.id) {
        window.location.href = withBasePath(`/passages/${params.data.id}`);
      }
    });

    // Store chart globally
    window.timelineChart = chart;

    // Handle window resize
    window.addEventListener("resize", () => chart.resize());
  };

  document.addEventListener("DOMContentLoaded", () => {
    console.log("Timeline component loaded");
    
    const chartElement = document.getElementById("passages-timeline");
    const dataSource = chartElement?.getAttribute('data-source') || 'table';
    
    // For table view, use the data that's set by the table page
    if (dataSource === 'table') {
      const timelineData = window.passagesTimelineData || [];
      if (timelineData.length) {
        window.initializeTimeline(timelineData);
      }
    } else if (dataSource === 'search') {
      // For search view, just wait - the search widget will call initializeTimeline
      console.log("Timeline waiting for search widget to provide data...");
    }
  });
</script>