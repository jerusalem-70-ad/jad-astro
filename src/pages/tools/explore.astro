---
import PageLayout from "@/layouts/page-layout.astro";
import NavLink from "@/components/nav-link.astro";
import GenreWorkPiechart from "@/components/visualisations/genre-work-piechart.astro";
import BiblGraph from "@/components/visualisations/bibl-ref-graph.astro"
import BibleBooks from "@/components/visualisations/bible-books.astro";
import LiturgicalRefs from "@/components/visualisations/liturgical-ref.astro";
import NetworkAll from "@/components/visualisations/network-all.astro";
---

<PageLayout title="Patterns">
  <div class="m-auto w-full lg:px-16 py-8">
    <div class="lg:max-w-4/5 px-3 lg:px-0 m-auto grid gap-5 md:py-8 py-2">
      <h1 class="text-4xl font-semibold text-brand-800">
        Explore patterns in the data
      </h1>
      <p class="max-w-full prose">
        Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed porta maximus nunc, id 
        vestibulum odio. Phasellus pharetra tortor ut dolor finibus condimentum nec mattis diam. 
        Suspendisse lacus lorem, porttitor id commodo id, fermentum sit amet tortor. In quis 
        imperdiet justo, nec dictum massa. Orci varius natoque penatibus et magnis dis parturient 
        montes, nascetur ridiculus mus. Phasellus efficitur at tortor eu imperdiet. Donec aliquam 
        iaculis tortor, in sagittis ante pellentesque gravida. </p>
      
      <GenreWorkPiechart/>
      <BibleBooks/>
      <BiblGraph/>
      <LiturgicalRefs/>
     <NetworkAll />
    
    </div>
  </div>
</PageLayout>
