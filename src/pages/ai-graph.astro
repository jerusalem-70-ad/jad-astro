---
import PageLayout from '../layouts/page-layout.astro';
import GraphDb from '@/components/graph-db.svelte'
import AsideSearch from '@/components/aside-search.svelte';
import ToggleAside from '@/components/toggle-aside.svelte';
---
<PageLayout title="AI Graph">
    <ToggleAside client:only="svelte" title="AI-generated text similarity search">
        <AsideSearch slot="aside" client:only="svelte" enableGraph={true} />
        <GraphDb slot="main" client:only="svelte" />
    </ToggleAside>
</PageLayout>