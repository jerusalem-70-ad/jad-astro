---
import PageLayout from "@/layouts/page-layout.astro";
import NavLink from "@/components/nav-link.astro";
import CheckListItem from "@/components/ui/check-list-item.astro"
---
<PageLayout title="data">
	<div class=" mx-auto w-full max-w-(--breakpoint-lg) px-3 md:px-16 py-10 grid gap-3">
		<div class="p-4 md:p-8 border-neutral-300 rounded-md bg-white shadow-lg">
				<h1 class="text-2xl md:text-4xl font-semibold text-brand-900 pb-4">
					Datasets
				</h1>
				 <p>Each dataset is presented as an interactive table, allowing users 
            to sort and filter data, customize the display, and export results for further analysis.</p>
        </div>       
        <div class="border-neutral-300 rounded-md bg-white shadow-lg p-5">
       
            <ul class="space-y-2">
                <CheckListItem>
                    <NavLink href="/data/passages">Passages</NavLink>
                </CheckListItem>
                <CheckListItem>
                    <NavLink href="/data/works">Works</NavLink>
                </CheckListItem>
                <CheckListItem>
                    <NavLink href="/data/authors">Authors</NavLink>
                </CheckListItem>
                <CheckListItem>
                    <NavLink href="/data/manuscripts">Manuscripts</NavLink>
                </CheckListItem>
                <CheckListItem>
                    <NavLink href="/data/keywords">Keywords</NavLink>
                </CheckListItem>
                <CheckListItem>
                    <NavLink href="/data/clusters">Clusters</NavLink>
                </CheckListItem>
                <CheckListItem>
                    <NavLink href="/data/liturgical-refs">Liturgical references</NavLink>
                </CheckListItem>
                <CheckListItem>
                    <NavLink href="/data/biblical-refs">Biblical references</NavLink>
                </CheckListItem>
            </ul>
        </div>
    </div>
</PageLayout>