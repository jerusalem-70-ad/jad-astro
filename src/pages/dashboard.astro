---
import SearchPanel from "@/components/search/search-panel.svelte"
import PageLayout from "@/layouts/page-layout.astro"
import Graph from "@/components/visualisations/passage-tree-d3.svelte"
import Dialog from "@/components/visualisations/dialog-card.svelte"
import GenrePieChart from "@/components/visualisations/genre-piechart.svelte";
import BiblBookGraph from "@/components/visualisations/bible-books.svelte"
---
<PageLayout title="Dashboard">
    <div class="flex h-screen">
        <aside class="sticky top-0 self-start w-80">
            <SearchPanel client:only="svelte"></SearchPanel>
        </aside>
        <div class="grid grid-cols-5 gap-5 overflow-auto p-4">
            <div class="col-span-3 flex justify-center" >
                <Graph client:only="svelte"/>
            </div>
            <div class="col-span-2">
                <GenrePieChart client:only="svelte" />
            </div>
            <div class="col-span-2">
                <BiblBookGraph client:only="svelte"/>
            </div>
        </div>
    </div>
    <Dialog client:only="svelte"/>       
</PageLayout>