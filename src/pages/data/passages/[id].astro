---
import PageLayout from "@/layouts/page-layout.astro";
import passages from "@/content/data/passages.json";
import { Icon } from "astro-icon/components";
import NavLink from "@/components/nav-link.astro";
import Article from "@/components/article.astro";
import type { Passage } from "@/types";
import ChronologicalTree from "@/components/visualisations/chronological-tree.astro";
import {addItalics} from "@/lib/utils.js";
import AsideSearch from "@/components/aside-search.svelte";

export async function getStaticPaths() {
  const paths = Object.values(passages).map((passage) => ({
    params: { id: passage.jad_id.toString() },
    props: { data: passage as Passage },
  }));
  return paths;
}

const { data: passage } = Astro.props;


// passage as source (look where one passage is used as source for another)


const usedBy = passage.transmission_graph.graph.nodes
.filter((node) => node.nodeType === "descendant" && node.depth === 0)
.map((node) => {
  return {
    jad_id: node.jad_id,
    id: node.id,
    passage: node.passage,
    work: node.work,
    author: node.author
  }
})

const statusConfig = {
  recorded: {
    label: "Recorded",
    level: 1,
    color: "bg-gray-500"
  },
  'edited in detail': {
    label: "Edited",
    level: 2,
    color: "bg-amber-500"
  },
  'fully analysed': {
    label: "Fully Analysed",
    level: 3,
    color: "bg-green-600"
  }
} as const;

const status = statusConfig[passage.status as keyof typeof statusConfig];
const steps = [1, 2, 3];

---

<PageLayout title=`passage #${passage.id.toString()}`>
  <div id="main-container" class="grid grid-cols-1 md:grid-cols-[16rem_1fr] md:gap-2">
    <div class="hidden md:block">
      <AsideSearch client:only="svelte"  />
    </div>
    <Article
      prevLink={`/data/passages/${passage.prev.id}`}
      nextLink={`/data/passages/${passage.next.id}`}
      mainTitle=`Passage #${passage.id}: ${passage.passage} `
    >
    <div class="grid gap-4">
      <dl
        class="grid grid-cols-[1fr_5fr] text-sm md:text-base md:leading-5 border border-neutral-300"
      >
        <dt
          class="font-semibold text-brand-800 border-r border-neutral-300 p-2 bg-brand-50"
        >
          Author:
        </dt>
        <dd class="pl-5 p-2 bg-brand-50">
          {
            passage.work.length > 0 && passage.work[0].author.length > 0 ? (
              <NavLink href={`/data/authors/${passage.work[0].author[0].jad_id}`}>
                {passage.work[0].author[0]?.name}{" "}
                {passage.work[0].author_certainty === false && " (?)"}
                {passage.work[0].author[0]?.occupation ? `(${passage.work[0].author[0].occupation})` : ""}
              </NavLink>
            ) : (
              "N/A"
            )
          }
        </dd>
        <dt
            class="font-semibold text-brand-800 border-r border-neutral-300 p-2"
          >
            Work:
          </dt>
          <dd class="pl-5 p-2">
            {
              passage.work.length > 0
                ? passage.work.map((werk, index) => (
                    <>
                      <NavLink href={`/data/works/${werk.jad_id}`}>
                        {werk.title}
                      </NavLink>
                      {index < passage.work.length - 1 && ", "}
                    </>
                  ))
                  : "N/A"
                }                
            {passage.work[0]?.date[0]?.value ? ` (${passage.work[0]?.date[0]?.value })` : ""}
            
          </dd>
          <dt
            class="font-semibold text-brand-800 border-r border-neutral-300 p-2 bg-brand-50"
          >
            Position in work:
          </dt>
          <dd class="pl-5 p-2 bg-brand-50">
            {passage.position_in_work ? passage.position_in_work : "N/A"}
          </dd>
          <dt
            class="font-semibold text-brand-800 border-r border-neutral-300 p-2"
          >
            Manuscripts:
          </dt>
          <dd class="pl-5 p-2">
            {passage.mss_occurrences &&
              passage.mss_occurrences?.length > 0 ? (
                <ul id="mssList">
                  {passage.mss_occurrences
                  .sort((a, b) =>
                    a.manuscript
                      .normalize("NFKD")
                      .replace(/\s+/g, " ")
                      .localeCompare(
                        b.manuscript.normalize("NFKD").replace(/\s+/g, " "),
                        undefined,
                        { numeric: true }
                      )
                  ).slice(0, 4) // showing first 4 items                 
                  .map((ms) => (
                    <li class={ms.main_ms ? "font-semibold" : ""}>
                      <NavLink href={`/data/manuscripts/${ms.jad_id}`}>
                        {ms.manuscript}
                        </NavLink>
                      {/* add exact position preprocessed from json ms_occurences */}
                      {ms.position_in_ms &&        
                            <span>
                              (f. {ms.position_in_ms})
                              {ms.facsimile_position && (
                                <NavLink href={ms.facsimile_position}>
                                  Facsimile{" "}
                                  <Icon
                                    name="lucide:external-link"
                                    class="size-4 inline-flex"
                                  />
                                </NavLink>
                              )}
                            </span>
                          }
                    </li>
                  ))} 
                  {/* //hidden extra items */}
                      {passage.mss_occurrences.slice(4).map((ms) => (
                        <li  class="hidden extra-item">
                      <NavLink href={`/data/manuscripts/${ms.jad_id}`}>
                        {ms.manuscript}
                        </NavLink>
                      {/* add exact position preprocessed from json ms_occurences */}
                      {ms.position_in_ms &&        
                            <span>
                              (f. {ms.position_in_ms})
                              {ms.facsimile_position && (
                                <NavLink href={ms.facsimile_position}>
                                  Facsimile{" "}
                                  <Icon
                                    name="lucide:external-link"
                                    class="size-4 inline-flex"
                                  />
                                </NavLink>
                              )}
                            </span>
                          }
                    </li>))}

              </ul>) : "N/A"
            }
             {passage.mss_occurrences.length > 4 && (
    <button  
  data-target="mssList" class="toggleVisible text-brand-800 underline mt-2 cursor-pointer">
      Show more
    </button>
  )}
          </dd>
          <dt
            class="font-semibold text-brand-800 border-r border-neutral-300 p-2 bg-brand-50"
          >
            Biblical references:
          </dt>
          <dd class="pl-5 p-2 bg-brand-50 ">
             {
              passage.biblical_references.length > 0
                ? <ul class="sm:flex sm:flex-wrap sm:gap-2">
                    {/* map through biblical_references and create a span for each reference */}
                  {passage.biblical_references
                  .sort((a, b) => a.key - b.key)
                    .map((reference) => (
                      <li class="group relative">
                        <NavLink
                            href={`/data/biblical-refs/${reference.jad_id}`}
                            class="flex underline underline-offset-4 decoration-dotted"
                          >
                            {reference.value}
                           
                          </NavLink>
                       <span class="hidden sm:block italic invisible group-hover:visible absolute z-10 w-[300px] top-8 left-0 border-brand-700 border text-brand-900 bg-brand-50 opacity-95 p-2 rounded-sm shadow-sm text-sm">
                          {reference.text}
                        </span>
                      </li>
                    ))
                    .reduce((prev, curr, idx) =>
                    idx === 0
                      ? [curr]
                      : [prev, <span class="hidden sm:block mx-1">|</span>, curr]
                  )}
                </ul>
                : "N/A"
            }
          </dd>
         
          <dt
            class="font-semibold text-brand-800 border-r border-neutral-300 p-2"
          >
            Liturgical references:
          </dt>
          <dd class="pl-5 p-2">
            {
              passage.liturgical_references.length > 0
                ? <ul class="sm:flex sm:flex-wrap sm:gap-2">
                    {/* map through biblical_references and create a span for each reference */}
                  {passage.liturgical_references                          
                    .map((reference, index) => (
                   <li class="group relative">
                    <NavLink href={`/data/liturgical-refs/jad_liturgical_reference__${reference.id}`}>
                      {reference.value}                        
                      </NavLink>
                      {index < passage.liturgical_references.length - 1 && ", "}
                       
                       {reference.description && (
                        <span class="hidden sm:block italic invisible group-hover:visible absolute z-10 w-[300px] top-8 left-0 border-brand-700 border text-brand-900 bg-brand-50 opacity-95 p-2 rounded-sm shadow-sm text-sm">
                          {reference.description}
                        </span>)}
                   </li>
                      ))}
                      </ul>
                : "N/A"
            }
          </dd>
           <dt
            class="font-semibold text-brand-800 bg-brand-50 border-r border-neutral-300 p-2"
          >
            Status:
          </dt>
          <dd class="pl-5 p-2 bg-brand-50">
            {status ? (
              <div class="inline-flex items-center gap-2 text-sm">
                {steps.map((step) => (
                  <span
                    class={`w-4 h-4 rounded-full border border-neutral-400 ${
                      step === status.level ? status.color : "bg-white"
                    }`}
                  ></span>
                ))}

                <span class="ml-1">{status.label}</span>
              </div>
            ) : "N/A"}
          </dd>
      </dl>
        
          <dl class="grid grid-cols-[1fr_5fr] text-sm md:text-base md:leading-5 border border-neutral-300">
            <dt
              class="font-semibold text-brand-800 border-r border-neutral-300 p-2 bg-brand-50"
            >
              Sources:
            </dt>
            <dd class="pl-5 p-2  bg-brand-50">
              
                {
                  passage.source_passage.length > 0 ? (<ul class="list-disc list-inside" id="listSources">
                    {passage.source_passage.slice(0, 4).map((source) => (
                        <li>
                          {source.author ? (
                            <span>
                              {source.author} -{" "}
                              <span class="italic">{source.title}</span>
                            </span>
                          ) : (
                            <span class="italic">{source.title}</span>
                          )}
                          <Icon
                            name="lucide:arrow-right"
                            class="size-4 text-brand-800 inline-flex"
                          />
                          <NavLink href={`/data/passages/${source.jad_id}`}>
                            ({source.id}) {source.passage}
                          </NavLink>
                        </li>
                      ))}

                      {/* //hidden extra items */}
                      {passage.source_passage.slice(4).map((source) => (
                        <li class="hidden extra-item">
                          {source.author ? (
                            <span>
                              {source.author} -{" "}
                              <span class="italic">{source.title}</span>
                            </span>
                          ) : (
                            <span class="italic">{source.title}</span>
                          )}
                          <Icon
                            name="lucide:arrow-right"
                            class="size-4 text-brand-800 inline-flex"
                          />
                          <NavLink href={`/data/passages/${source.jad_id}`}>
                            ({source.id}) {source.passage}
                          </NavLink>
                        </li>))}

              </ul>) : "N/A"
                }
                 {passage.source_passage.length > 4 && (
    <button
  data-target="listSources" class="toggleVisible text-brand-800 underline mt-2 cursor-pointer">
      Show more
    </button>
  )}
            </dd>
            <dt class="font-semibold text-brand-800 border-r border-neutral-300 p-2">
  Used by:
</dt>
<dd class="pl-5 p-2">
  {
    usedBy.length > 0 ? (
      <ul class="list-disc list-inside" id="usedByList">
        {usedBy.slice(0, 4).map((passage) => (
          <li>
            {passage.author ? (
              <span>
                {passage.author} -{" "}
                <span class="italic">{passage.work}</span>
              </span>
            ) : (
              <span class="italic">{passage.work}</span>
            )}
            <Icon
              name="lucide:arrow-right"
              class="size-4 text-brand-800 inline-flex"
            />
            <NavLink href={`/data/passages/${passage.jad_id}`}>
              ({passage.id}) {passage.passage}
            </NavLink>
          </li>
        ))}

        {/* hidden extra items */}
        {usedBy.slice(4).map((passage) => (
          <li class="hidden extra-item">
             {passage.author ? (
              <span>
                {passage.author} -{" "}
                <span class="italic">{passage.work}</span>
              </span>
            ) : (
              <span class="italic">{passage.work}</span>
            )}
            <Icon
              name="lucide:arrow-right"
              class="size-4 text-brand-800 inline-flex"
            />
            <NavLink href={`/data/passages/${passage.jad_id}`}>
              ({passage.id}) {passage.passage}
            </NavLink>
          </li>
        ))}
      </ul>
    ) : (
      "N/A"
    )
  }
<div class="flex mt-2 justify-between">
  <!-- button for showing extra items -->
    {usedBy.length > 4 && (
   <button
  data-target="usedByList" class="toggleVisible text-brand-800 underline mt-2 cursor-pointer">
        Show more
      </button>
    )}
  
    <!-- button for comparison tool -->
      {passage.source_passage.length > 0 || usedBy.length > 0 
      ? (
      <NavLink href={`/tools/text-comparisons/${passage.jad_id}`} class="py-2 px-5 bg-brand-400 hover:bg-brand-700 text-brand-50 border border-brand-600 rounded-md cursor-pointer">
        Compare texts
      </NavLink>)
      : ""}
</div>
</dd>
              {passage.source_passage.length > 0 || usedBy.length > 0 ? (
            <dt
            class="hidden sm:block font-semibold text-brand-800 border-r border-neutral-300 p-2"
          >
            Transmission:
          </dt>
          <dd class="hidden sm:block pl-5 p-2">
            {passage.transmission_graph && (
              <details>
              <summary class="cursor-pointer p-2  bg-brand-800/90 hover:bg-brand-700 text-brand-50 w-60 rounded-md">Transmission graph</summary>
              <div>               
                  <ChronologicalTree
        transmissionGraph={passage.transmission_graph}/>
              </div></details>
              ) 
            }
          </dd>
          )
          : ''}
          </dl>
          <dl class="grid grid-cols-[1fr_5fr] text-sm md:text-base md:leading-5 border border-neutral-300">
          <dt
            class="font-semibold text-brand-800 border-r border-neutral-300 p-2 bg-brand-50"
          >
            Cluster:
          </dt>
          <dd class="pl-5 p-2 bg-brand-50">
            {
              passage.part_of_cluster.length > 0
                ? 
                <ul class="sm:flex sm:flex-wrap sm:gap-2">
                  {passage.part_of_cluster.map((cluster) => (
                    <li class="group relative">
                      <NavLink href={`/data/clusters/${cluster.jad_id}`}>
                        {cluster.value}
                      </NavLink>
                       {cluster.description && (
                        <span class="hidden sm:block italic invisible group-hover:visible absolute z-10 w-[300px] top-8 left-0 border-brand-700 border text-brand-900 bg-brand-50 opacity-95 p-2 rounded-sm shadow-sm text-sm">
                          {cluster.description}
                        </span>)}
                    </li>
                  ))}
                </ul>               
                : "N/A"
            }
          </dd>
          <dt
            class="font-semibold text-brand-800 border-r border-neutral-300 p-2"
          >
            Keywords:
          </dt>
         <dd class="pl-5 p-2">
          <div class="grid grid-cols-2 lg:grid-cols-4 gap-2">
            <div class="border border-neutral-300 rounded-md px-2 py-1">
              <span id="elements-roman-conquest-heading" class="text-sm font-medium text-brand-800">Elements Roman conquest</span>
              <ul aria-labelledby="elements-roman-conquest-heading" class="mt-1 flex flex-wrap gap-1">
                {passage.keywords.find(keyword => keyword.label === "Elements Roman conquest")?.subkeywords.sort((a, b) => a.label.localeCompare(b.label)).map((sb) => (
                  <li class="relative group ">
                    <NavLink
                      href={`/data/keywords/${sb.jad_id}`}
                      class="rounded-full bg-amber-500/50 px-2 py-0.5 text-sm text-brand-950 hover:bg-brand-300 hover:text-white transition-colors"
                    >
                      {sb.label}
                    </NavLink>

                    {sb.description && (
                      <span class="pointer-events-none hidden absolute left-0 top-full z-30 mt-2 w-max max-w-[320px] rounded border border-brand-700 bg-brand-50 p-2 text-sm italic text-brand-900 shadow-lg sm:group-hover:block">
                        {sb.description}
                      </span>
                    )}
                  </li>
                ))}
              </ul>
            </div>
            <div class="border border-neutral-300 rounded-md px-2 py-1">
              <span id="roman-empire-heading" class="text-sm font-medium text-brand-800">Roman Empire</span>
              <ul aria-labelledby="roman-empire-heading" class="mt-1 flex flex-wrap gap-1">
                {passage.keywords.find(keyword => keyword.label === "Roman Empire")?.subkeywords.sort((a, b) => a.label.localeCompare(b.label)).map((sb) => (
                  <li class="relative group">
                    <NavLink
                      href={`/data/keywords/${sb.jad_id}`}
                      class="rounded-full bg-amber-500/50 px-2 py-0.5 text-sm text-brand-950 hover:bg-brand-300 hover:text-white transition-colors"
                    >
                      {sb.label}
                    </NavLink>

                    {sb.description && (
                      <span class="pointer-events-none hidden absolute left-0 top-full z-30 mt-2 w-max max-w-[320px] rounded border border-brand-700 bg-brand-50 p-2 text-sm italic text-brand-900 shadow-lg sm:group-hover:block">
                        {sb.description}
                      </span>
                    )}
                  </li>
                ))}
              </ul>
            </div>
            <div class="border border-neutral-300 rounded-md px-2 py-1">
              <span id="biblical-elements-heading" class="text-sm font-medium text-brand-800">Biblical elements</span>
              <ul aria-labelledby="biblical-elements-heading" class="mt-1 flex flex-wrap gap-1">
                {passage.keywords.find(keyword => keyword.label === "Biblical elements")?.subkeywords.sort((a, b) => a.label.localeCompare(b.label)).map((sb) => (
                  <li class="relative group">
                    <NavLink
                      href={`/data/keywords/${sb.jad_id}`}
                      class="rounded-full bg-amber-500/50 px-2 py-0.5 text-sm text-brand-950 hover:bg-brand-300 hover:text-white transition-colors"
                    >
                      {sb.label}
                    </NavLink>

                    {sb.description && (
                      <span class="pointer-events-none hidden absolute left-0 top-full z-30 mt-2 w-max max-w-[320px] rounded border border-brand-700 bg-brand-50 p-2 text-sm italic text-brand-900 shadow-lg sm:group-hover:block">
                        {sb.description}
                      </span>
                    )}
                  </li>
                ))}
              </ul>
            </div>
            <div class="border border-neutral-300 rounded-md px-2 py-1">
              <span id="contemporary-pertinence-heading" class="text-sm font-medium text-brand-800">Contemporary pertinence</span>
              <ul aria-labelledby="contemporary-pertinence-heading" class="mt-1 flex flex-wrap gap-1">
                {passage.keywords.find(keyword => keyword.label === "Contemporary pertinence")?.subkeywords.sort((a, b) => a.label.localeCompare(b.label)).map((sb) => (
                  <li class="relative group">
                    <NavLink
                      href={`/data/keywords/${sb.jad_id}`}
                      class="rounded-full bg-amber-500/50 px-2 py-0.5 text-sm text-brand-950 hover:bg-brand-300 hover:text-white transition-colors"
                    >
                      {sb.label}
                    </NavLink>

                    {sb.description && (
                      <span class="pointer-events-none hidden absolute left-0 top-full z-30 mt-2 w-max max-w-[320px] rounded border border-brand-700 bg-brand-50 p-2 text-sm italic text-brand-900 shadow-lg sm:group-hover:block">
                        {sb.description}
                      </span>
                    )}
                  </li>
                ))}
              </ul>
            </div>
          </div>
  
        </dd>
           {
              passage.explicit_contemp_ref
                ?  
                (<dt class="font-semibold text-brand-800 border-r border-neutral-300 p-2">
                  Contemporary Reference:
                </dt>
                <dd class="pl-5 p-2">
                {passage.explicit_contemp_ref}
                </dd>) 
                : "" }
          <dt
            class="font-semibold text-brand-800 border-r border-neutral-300 p-2 bg-brand-50"
          >
            Passage found in:
          </dt>
          <dd class="pl-5 p-2 bg-brand-50">
            {
              passage.occurrence_found_in?.length > 0 && passage.occurrence_found_in[0]?.value != 'Secondary literature'
                ? passage.occurrence_found_in.map((find) => find.value).join(", ")
                : ""
            }
            {passage.note && (<span set:html={addItalics(passage.note)}></span>)}
            
          </dd>
           <dt
            class="font-semibold text-brand-800 border-r border-neutral-300 p-2 bg-brand-50"
          >
            Text taken from:
          </dt>
          <dd class="pl-5 p-2 bg-brand-50">
            {
              passage.text_taken_from?.length > 0 && passage.text_taken_from.map(tx => tx.value).join(", ")
               
            }   
          </dd>
          <dt
            class="font-semibold text-brand-800 border-r border-neutral-300 p-2"
          >
            Edition:
          </dt>
          <dd class="pl-5 p-2">
            {passage.work[0]?.edition != 'Other edition' 
              ? passage.work[0]?.edition
              : ''}
             {passage?.work[0]?.link_digital_editions && 
            <NavLink href={passage.work[0]?.link_digital_editions}> Facsimile of the whole work <Icon name="lucide:external-link" class="size-4 text-brand-800 inline-flex"/></NavLink>
            } 
           {passage?.edition_link && 
            <NavLink href={passage.edition_link}> Facsimile <Icon name="lucide:external-link" class="size-4 text-brand-800 inline-flex"/></NavLink>
            }
          </dd>
            <dt
            class="font-semibold text-brand-800 border-r border-neutral-300 p-2 bg-brand-50"
          >
            Full text:
          </dt>
         <dd class="pl-5 p-2 italic bg-brand-50">
          <!-- // check if there is a // should be rendered as zeilenmbruch -->
           {passage.text_paragraph
              ? passage.text_paragraph.split(" // ").map((part, i) => (
                    <>
                      {i > 0 && (
                        <>
                          {" // "}
                          <br />
                        </>
                      )}
                      {part}
                    </>
                  ))
                : "N/A"
            }
          </dd>     
        </dl> 
        <div class="flex gap-3 justify-end">
          <NavLink href=`/download/tei/passages/${passage.jad_id}.xml` class="button-custom justify-self-end">TEI-XML</NavLink>
          <NavLink href=`/download/json/passages/${passage.jad_id}.json` class="button-custom justify-self-end">JSON</NavLink>
        </div>  
      </div>
    </Article>
  </div>
</PageLayout>

<script>
  document.addEventListener("DOMContentLoaded", () => {
  document.querySelectorAll<HTMLElement>(".toggleVisible").forEach(button => {
    button.addEventListener("click", () => {
      const targetId = button.dataset.target;
      const extraItems = document.querySelectorAll(
        `#${targetId} .extra-item`
      );

      if (!extraItems.length) return;

      const isHidden = extraItems[0].classList.contains("hidden");

      extraItems.forEach(item => {
        item.classList.toggle("hidden");
      });

      button.textContent = isHidden ? "Show less" : "Show more";
    });
  });
});
</script>