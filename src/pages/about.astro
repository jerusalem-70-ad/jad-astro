---
import PageLayout from "@/layouts/page-layout.astro";
import NavLink from "@/components/nav-link.astro";
import CheckListItem from "@/components/ui/check-list-item.astro"
---
<PageLayout title="About">
	<div class=" mx-auto w-full max-w-(--breakpoint-lg) px-3 md:px-16 py-10 grid gap-3">
		<div class="p-4 md:p-8 border-neutral-300 rounded-md bg-white shadow-lg">
				<h1 class="text-2xl md:text-4xl font-semibold text-brand-900 pb-4">
					About
				</h1>
				 <p></p>
			</div>       
<div class="border-neutral-300 rounded-md bg-white shadow-lg p-5">
       
        <ul class="space-y-2">
            <CheckListItem>
                <NavLink href="/about/project">Project</NavLink>
            </CheckListItem>
            <CheckListItem>
                <NavLink href="/about/technical">Technical Implementation</NavLink>
            </CheckListItem>
            <CheckListItem>
                <NavLink href="/about/faqs">FAQs</NavLink>
            </CheckListItem>
            <CheckListItem>
                <NavLink href="/about/oai-pmh">OAI-PMH</NavLink>
            </CheckListItem>
        </ul>
        </div>
    </div>
</PageLayout>